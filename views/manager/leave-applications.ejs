<div class="bg-white p-6 rounded-lg shadow-md">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Leave Applications</h1>
    <div class="flex space-x-2">
      <button id="filter-all" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 active">
        All
      </button>
      <button id="filter-pending" class="px-4 py-2 bg-gray-200 text-gray-700 text-sm font-medium rounded hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
        Pending
      </button>
      <button id="filter-approved" class="px-4 py-2 bg-gray-200 text-gray-700 text-sm font-medium rounded hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
        Approved
      </button>
      <button id="filter-rejected" class="px-4 py-2 bg-gray-200 text-gray-700 text-sm font-medium rounded hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
        Rejected
      </button>
    </div>
  </div>
  
  <% if (leaves && leaves.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Leave Type</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Duration</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Days</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Applied On</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200" id="leave-applications-tbody">
          <% leaves.forEach(leave => { %>
            <tr class="hover:bg-gray-50 leave-row" data-status="<%= leave.status %>">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="font-medium text-gray-900"><%= leave.employeeName %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap capitalize">
                <%= leave.leaveType %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= leave.startDate.toLocaleDateString() %> to <%= leave.endDate.toLocaleDateString() %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= Math.ceil(Math.abs(new Date(leave.endDate) - new Date(leave.startDate)) / (1000 * 60 * 60 * 24)) + 1 %> days
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if (leave.status === 'pending') { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                    Pending
                  </span>
                <% } else if (leave.status === 'approved') { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                    Approved
                  </span>
                <% } else { %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                    Rejected
                  </span>
                <% } %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= leave.appliedDate.toLocaleDateString() %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <a href="/manager/leave-applications/<%= leave.id %>" class="text-blue-600 hover:text-blue-900">
                  <%= leave.status === 'pending' ? 'Review' : 'View' %>
                </a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    
    <div id="no-results" class="hidden text-center py-8 bg-gray-50 rounded-lg mt-4">
      <div class="text-5xl text-gray-300 mb-4">
        <i class="fas fa-search"></i>
      </div>
      <h3 class="text-lg font-medium text-gray-700 mb-2">No matching applications</h3>
      <p class="text-gray-500">Try changing your filters</p>
    </div>
  <% } else { %>
    <div class="text-center py-8 bg-gray-50 rounded-lg">
      <div class="text-5xl text-gray-300 mb-4">
        <i class="fas fa-clipboard-list"></i>
      </div>
      <h3 class="text-lg font-medium text-gray-700 mb-2">No leave applications found</h3>
      <p class="text-gray-500">There are no leave applications to review</p>
    </div>
  <% } %>
  
  <div class="mt-8">
    <a href="/manager/dashboard" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
      <i class="fas fa-arrow-left mr-2"></i> Back to Dashboard
    </a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterAll = document.getElementById('filter-all');
    const filterPending = document.getElementById('filter-pending');
    const filterApproved = document.getElementById('filter-approved');
    const filterRejected = document.getElementById('filter-rejected');
    const leaveRows = document.querySelectorAll('.leave-row');
    const noResults = document.getElementById('no-results');
    
    function updateFilterButtons(activeButton) {
      [filterAll, filterPending, filterApproved, filterRejected].forEach(button => {
        if (button === activeButton) {
          button.classList.remove('bg-gray-200', 'text-gray-700');
          button.classList.add('bg-blue-600', 'text-white', 'active');
        } else {
          button.classList.remove('bg-blue-600', 'text-white', 'active');
          button.classList.add('bg-gray-200', 'text-gray-700');
        }
      });
    }
    
    function filterLeaveRows(status) {
      let visibleCount = 0;
      
      leaveRows.forEach(row => {
        if (status === 'all' || row.dataset.status === status) {
          row.classList.remove('hidden');
          visibleCount++;
        } else {
          row.classList.add('hidden');
        }
      });
      
      if (visibleCount === 0) {
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
      }
    }
    
    filterAll.addEventListener('click', function() {
      updateFilterButtons(this);
      filterLeaveRows('all');
    });
    
    filterPending.addEventListener('click', function() {
      updateFilterButtons(this);
      filterLeaveRows('pending');
    });
    
    filterApproved.addEventListener('click', function() {
      updateFilterButtons(this);
      filterLeaveRows('approved');
    });
    
    filterRejected.addEventListener('click', function() {
      updateFilterButtons(this);
      filterLeaveRows('rejected');
    });
  });
</script>