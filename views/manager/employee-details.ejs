<div class="bg-white p-6 rounded-lg shadow-md">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Employee Details</h1>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
    <div class="bg-blue-50 p-6 rounded-lg border border-blue-100">
      <h2 class="text-lg font-medium text-gray-800 mb-4">Personal Information</h2>
      <div class="space-y-3">
        <div>
          <h3 class="text-xs font-medium text-gray-500 uppercase tracking-wider">Name</h3>
          <p class="text-base font-medium text-gray-800"><%= employee.name %></p>
        </div>
        <div>
          <h3 class="text-xs font-medium text-gray-500 uppercase tracking-wider">Email</h3>
          <p class="text-base font-medium text-gray-800"><%= employee.email %></p>
        </div>
        <div>
          <h3 class="text-xs font-medium text-gray-500 uppercase tracking-wider">Department</h3>
          <p class="text-base font-medium text-gray-800"><%= employee.department %></p>
        </div>
        <div>
          <h3 class="text-xs font-medium text-gray-500 uppercase tracking-wider">Joined Date</h3>
          <p class="text-base font-medium text-gray-800"><%= employee.createdAt.toDateString() %></p>
        </div>
      </div>
    </div>
    
    <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
      <h2 class="text-lg font-medium text-gray-800 mb-4">Leave Balance</h2>
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-blue-100 p-4 rounded-lg">
          <h3 class="text-sm font-medium text-blue-800 mb-1">Annual Leave</h3>
          <p class="text-2xl font-bold text-blue-800"><%= leaveBalance.annual %> days</p>
        </div>
        <div class="bg-green-100 p-4 rounded-lg">
          <h3 class="text-sm font-medium text-green-800 mb-1">Sick Leave</h3>
          <p class="text-2xl font-bold text-green-800"><%= leaveBalance.sick %> days</p>
        </div>
        <div class="bg-purple-100 p-4 rounded-lg">
          <h3 class="text-sm font-medium text-purple-800 mb-1">Casual Leave</h3>
          <p class="text-2xl font-bold text-purple-800"><%= leaveBalance.casual %> days</p>
        </div>
        <div class="bg-yellow-100 p-4 rounded-lg">
          <h3 class="text-sm font-medium text-yellow-800 mb-1">Compensatory</h3>
          <p class="text-2xl font-bold text-yellow-800"><%= leaveBalance.compensatory %> days</p>
        </div>
      </div>
    </div>
  </div>
  
  <div class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold text-gray-800">Leave History</h2>
    </div>
    
    <% if (leaves && leaves.length > 0) { %>
      <div class="overflow-x-auto bg-white rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Leave Type</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Duration</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Days</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Applied On</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% leaves.forEach(leave => { %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap capitalize">
                  <%= leave.leaveType %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= leave.startDate.toLocaleDateString() %> to <%= leave.endDate.toLocaleDateString() %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= Math.ceil(Math.abs(new Date(leave.endDate) - new Date(leave.startDate)) / (1000 * 60 * 60 * 24)) + 1 %> days
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if (leave.status === 'pending') { %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                      Pending
                    </span>
                  <% } else if (leave.status === 'approved') { %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                      Approved
                    </span>
                  <% } else { %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                      Rejected
                    </span>
                  <% } %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= leave.appliedDate.toLocaleDateString() %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <a href="/manager/leave-applications/<%= leave.id %>" class="text-blue-600 hover:text-blue-900">
                    <%= leave.status === 'pending' ? 'Review' : 'View' %>
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-center py-8 bg-gray-50 rounded-lg">
        <div class="text-5xl text-gray-300 mb-4">
          <i class="fas fa-calendar-times"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-700 mb-2">No leave history</h3>
        <p class="text-gray-500">This employee hasn't applied for any leave yet</p>
      </div>
    <% } %>
  </div>
  
  <div class="flex justify-between">
    <a href="/manager/employees" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
      <i class="fas fa-arrow-left mr-2"></i> Back to Employees
    </a>
  </div>
</div>