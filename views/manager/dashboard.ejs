<div class="space-y-8">
  <div class="bg-white p-6 rounded-lg shadow-md">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-800">Manager Dashboard</h1>
      <div class="text-sm text-gray-500"><%= new Date().toLocaleDateString() %></div>
    </div>
    
<div class="grid grid-cols-1 md:grid-cols-1 gap-6">
      <div class="bg-blue-50 p-6 rounded-lg border border-blue-100 flex items-center">
        <div class="rounded-full bg-blue-500 text-white p-3 mr-4">
          <i class="fas fa-clock text-xl"></i>
        </div>
        <div>
          <div class="text-sm font-medium text-blue-500">Pending Applications</div>
          <div id="pending-count" class="text-2xl font-bold text-blue-700"><%= leaves.filter(leave => leave.status === 'pending').length %></div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="bg-white p-6 rounded-lg shadow-md">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-semibold text-gray-800">Pending Leave Applications</h2>
      <a href="/manager/leave-applications" class="text-blue-600 hover:text-blue-800 text-sm font-medium flex items-center">
        View all applications
        <i class="fas fa-chevron-right ml-1 text-xs"></i>
      </a>
    </div>
    
    <% if (leaves && leaves.filter(leave => leave.status === 'pending').length > 0) { %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Leave Type</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Duration</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Days</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Applied On</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% leaves.filter(leave => leave.status === 'pending').forEach(leave => { %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="font-medium text-gray-900"><%= leave.employeeName %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap capitalize">
                  <%= leave.leaveType %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= leave.startDate.toLocaleDateString() %> to <%= leave.endDate.toLocaleDateString() %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= Math.ceil(Math.abs(new Date(leave.endDate) - new Date(leave.startDate)) / (1000 * 60 * 60 * 24)) + 1 %> days
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= leave.appliedDate.toLocaleDateString() %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <a href="/manager/leave-applications/<%= leave.id %>" class="text-blue-600 hover:text-blue-900">Review</a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-center py-8 bg-gray-50 rounded-lg">
        <div class="text-5xl text-gray-300 mb-4">
          <i class="fas fa-check-circle"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-700 mb-2">No pending applications</h3>
        <p class="text-gray-500">All leave applications have been reviewed</p>
      </div>
    <% } %>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-white p-6 rounded-lg shadow-md">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-800">Quick Actions</h2>
      </div>
      
      <div class="space-y-4">
        <a href="/manager/leave-applications" class="block p-4 bg-blue-50 rounded-lg border border-blue-100 hover:bg-blue-100 transition duration-300">
          <div class="flex items-center">
            <div class="flex-shrink-0 h-10 w-10 bg-blue-500 rounded-lg flex items-center justify-center text-white">
              <i class="fas fa-clipboard-list"></i>
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-medium text-gray-800">Review Applications</h3>
              <p class="text-sm text-gray-500">Manage pending leave applications</p>
            </div>
          </div>
        </a>
        
        <a href="/manager/employees" class="block p-4 bg-green-50 rounded-lg border border-green-100 hover:bg-green-100 transition duration-300">
          <div class="flex items-center">
            <div class="flex-shrink-0 h-10 w-10 bg-green-500 rounded-lg flex items-center justify-center text-white">
              <i class="fas fa-users"></i>
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-medium text-gray-800">View Employees</h3>
              <p class="text-sm text-gray-500">Manage department employees</p>
            </div>
          </div>
        </a>
      </div>
    </div>
    
    <div class="bg-white p-6 rounded-lg shadow-md">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-gray-800">Department Overview</h2>
      </div>
      
      <div class="text-center py-10 bg-gray-50 rounded-lg">
        <div class="text-5xl text-gray-300 mb-4">
          <i class="fas fa-chart-pie"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-700 mb-2">Analytics Coming Soon</h3>
        <p class="text-gray-500">We're working on adding department statistics</p>
      </div>
    </div>
  </div>
</div>

<script>
  async function fetchLeaveCounts() {
    try {
      const response = await fetch('/manager/api/leave-counts');
      if (!response.ok) throw new Error('Failed to fetch leave counts');
      const data = await response.json();
      updateLeaveCounts(data.counts);
    } catch (error) {
      console.error(error);
    }
  }

  function updateLeaveCounts(counts) {
    document.getElementById('pending-count').textContent = counts.pending;
    // Removed approved and rejected counts update as they are no longer displayed
    // document.getElementById('approved-count').textContent = counts.approved;
    // document.getElementById('rejected-count').textContent = counts.rejected;
  }

  document.addEventListener('DOMContentLoaded', () => {
    fetchLeaveCounts();

    document.addEventListener('leaveCountsUpdated', (event) => {
      updateLeaveCounts(event.detail);
    });
  });
</script>
